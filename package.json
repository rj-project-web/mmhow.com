{
  "name": "mmhow",
  "version": "0.1.0",
  "private": true,
  "description": "MMHow — How to make money: side hustles, online income, and investing",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation npm run generate:sitemap && cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:sitemap": "cross-env NODE_OPTIONS=--no-deprecation node --env-file=.env --import tsx/esm src/scripts/generate-sitemap.ts",
    "sitemap:check": "cross-env NODE_OPTIONS=--no-deprecation node --env-file=.env --import tsx/esm src/scripts/check-and-update-sitemap.ts",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed:admin": "cross-env NODE_OPTIONS=--no-deprecation node --env-file=.env --import tsx/esm src/scripts/seed-admin.ts",
    "republish:articles": "cross-env NODE_OPTIONS=--no-deprecation node --env-file=.env --import tsx/esm src/scripts/republish-articles-from-drafts.ts",
    "source-mapping:import": "cross-env NODE_OPTIONS=--no-deprecation node --env-file=.env --import tsx/esm src/scripts/import-source-mapping-to-cms.ts",
    "source-mapping:sync": "cross-env NODE_OPTIONS=--no-deprecation node --env-file=.env --import tsx/esm scripts/sync-source-mapping.mjs",
    "publish:category-batch": "node --env-file=.env scripts/publish-category-batch.mjs",
    "publish:zhihu-xhs-batch": "node --env-file=.env scripts/publish-zhihu-xhs-batch.mjs",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.10.0",
    "jsdom": "^26.0.0",
    "lucide-react": "^0.469.0",
    "next": "15.2.9",
    "payload": "3.85.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
